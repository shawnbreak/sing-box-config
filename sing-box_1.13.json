{
    "log": {
	"disabled": false,
	"level": "warn",
	"timestamp": true
    },
    "experimental": {
	"cache_file": {
	    "enabled": true
	},
	"clash_api": {
	    "external_controller": "127.0.0.1:9090",
	    "external_ui": "dashboard"
	}
    },
    "dns": {
        "servers": [
            {
		"tag": "remote-dns",
                "type": "https",
		"detour": "proxy",
                "server": "1.1.1.1"
            },
	    {
		"tag": "ai-dns",
                "type": "https",
		"detour": "ai",
                "server": "1.1.1.1"
            },
            {
                "tag": "local-dns",
                "type": "https",
		"detour": "direct",
                "server": "223.5.5.5"
            }
        ],
	"rules": [
	    {
		"rule_set": [
		    "geosite-cn",
		    "geoip-cn"
		],
		"server": "local-dns"
	    },
	    {
		"domain": [
                    "oa.linx-info.com",
                    "oax.linx-info.com",
                    "mail.linx-info.com",
                    "ff.cd.linx",
                    "xt.rd.in.linx"
		],
		"server": "local-dns"
	    },
	    {
                "domain_suffix": [
                    "openai.com",
                    "chatgpt.com",
                    "gemini.google.com",
                    "claude.ai" 
                ],
                "server": "ai-dns"
            },
	    {
		"rule_set": ["category-ads-all"],
		"action": "reject"
	    }
	],
	"final": "remote-dns",
        "strategy": "ipv4_only"
    },
    "route": {
	"auto_detect_interface": true,
	"default_domain_resolver": "local-dns",
	"final": "proxy",
	"rules": [
	    {
		"action": "sniff"
	    },
	    {
		"protocol": "dns",
		"action": "hijack-dns"
	    },
	    {
		"ip_is_private": true,
		"outbound": "direct"
	    },
	    {
		"rule_set": [
                    "geosite-cn",
                    "geoip-cn"
                ],
		"outbound": "direct"
	    },
	    {
		"domain": [
                    "oa.linx-info.com",
                    "oax.linx-info.com",
                    "mail.linx-info.com",
                    "ff.cd.linx",
                    "xt.rd.in.linx"
                ],
		"action": "route",
		"outbound": "direct"
	    },
            {
                "domain_suffix": [
                    "openai.com",
                    "chatgpt.com",
                    "gemini.google.com",
                    "claude.ai"
                ],
		"action": "route",
                "outbound": "ai"
            }
	],
	"rule_set": [
	    {
		"tag": "geosite-cn",
		"type": "remote",
		"format": "binary",
		"url": "https://fastly.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-cn.srs",
		"download_detour": "direct"
	    },
	    {
		"tag": "geoip-cn",
		"type": "remote",
		"format": "binary",
		"url": "https://fastly.jsdelivr.net/gh/SagerNet/sing-geoip@rule-set/geoip-cn.srs",
		"download_detour": "direct"
	    },
	    {
		"tag": "category-ads-all",
		"type": "remote",
		"format": "binary",
		"url": "https://fastly.jsdelivr.net/gh/SagerNet/sing-geosite@rule-set/geosite-category-ads-all.srs",
		"download_detour": "direct"
	    }
	]
    },
    "inbounds": [
        {
            "type": "tun",
            "tag": "tun-in",
            "address": [
                "172.18.0.1/30"
            ],
            "auto_route": true,
            "strict_route": true
        }
    ],
    "outbounds": [
	{
	    "type": "selector",
	    "tag": "proxy",
	    "outbounds": []
	},
	{
	    "type": "urltest",
	    "tag": "auto",
	    "interval": "10m",
	    "outbounds": []
	},
	{
	    "type": "selector",
	    "tag": "ai",
	    "outbounds": []
	},
	{
	    "type": "direct",
	    "tag": "direct",
	    "domain_resolver": "local-dns"
	}
    ]
}
